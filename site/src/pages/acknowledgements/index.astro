---
import LegalLayout from '../../layouts/LegalLayout.astro';
import { getLegalPage } from '../../lib/legal';

const { entry, Content } = await getLegalPage('acknowledgements', 'en');
const { title, description, updated } = entry.data;
---

<LegalLayout
  locale="en"
  pageKey="acknowledgements"
  title={`${title} - Cordierite`}
  description={description}
  updated={updated}
>
  <Content />
</LegalLayout>
