{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cordierite-site",
  "compatibility_date": "2026-06-29",
  "preview_urls": true,
  "assets": {
    "directory": ".",
    "html_handling": "auto-trailing-slash"
  },
  "routes": [
    {
      "pattern": "cordierite.veltiosoft.com",
      "custom_domain": true
    }
  ]
}
